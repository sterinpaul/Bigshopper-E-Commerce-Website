<section>
    <div class="admin-home-container">
    
        {{!-- <a class="btn btn-primary mr-5" href="/admin/add-user">Add User</a> --}}
        
        <table class="table table-striped" style="width:90%" id="productsTable">
            <thead>
              <tr>
                <th scope="col">No.</th>
                <th scope="col">Name</th>
                <th scope="col">Gender</th>
                <th scope="col">Email</th>
                <th scope="col">Mobile No.</th>
                
                <th scope="col" style="text-align:center;">Action</th>
              </tr>
            </thead>
            <tbody>

              {{#each users}}
              <tr>
                <td>{{inc @index}}</td>
                <td>{{this.fName}} {{this.lName}}</td>
                <td>{{this.gender}}</td>
                <td>{{this.email}}</td>
                <td>{{this.mobile}}</td>
                
                <td style="display:flex;flex-flow:column;">
                  <a href="/admin/edit-user?id={{this._id}}" class="btn btn-primary" style="margin-left:auto;margin-right:auto;">Edit User</a>

                  {{#if this.access}}
                  <a href="/admin/block-user?id={{this._id}}" class="btn btn-danger mt-1" style="margin-left:auto;margin-right:auto;" onclick="return confirm(`Do you want to block '{{this.fName}} {{this.lName}}' ?`)">Block</a>
                    {{else}}
                  <a href="/admin/unblock-user?id={{this._id}}" class="btn btn-primary mt-1" style="margin-left:auto;margin-right:auto;" onclick="return confirm(`Do you want to unblock '{{this.fName}} {{this.lName}}' ?`)">Unblock</a>
                    {{/if}}

                </td>
              </tr>
              {{/each}}

            </tbody>
        </table>
    </div>
</section>

